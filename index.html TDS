    .btn-row { display: flex; gap: 8px; margin-top: 20px; }
    .btn-primary { flex: 1; background: #E02020; border: none; border-radius: 4px; color: #fff; font-size: 11px; font-weight: 700; padding: 10px; letter-spacing: 1px; }
