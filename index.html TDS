    #hdr { background: #111; border-bottom: 1px solid #1e1e1e; position: sticky; top: 0; z-index: 100; }
    .hdr-inner { max-width: 1000px; margin: 0 auto; padding: 0 16px; }
    .hdr-top { display: flex; align-items: center; justify-content: space-between; height: 52px; }
