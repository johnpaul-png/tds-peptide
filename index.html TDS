        ${s.peptides.map(p => `
          <div class="card">
            <button class="delete-btn" onclick="deleteCard('${s.id}','${p.id}')">✕ DELETE</button>
            <div class="card-name">${p.name}</div>
            <div class="card-desc">${p.desc}</div>
            <div class="card-divider">
              <div class="card-label">RECONSTITUTION</div>
              <div class="card-recon">${p.recon}</div>
            </div>
            <div class="card-dose-wrap">
              <div class="card-label">DOSING</div>
              <div class="card-dose">${p.dose}</div>
            </div>
          </div>`).join('')}
      </div>
    </div>`).join('') +
    `<div class="footer">FOR RESEARCH PURPOSES ONLY · NOT FOR HUMAN CONSUMPTION · DM FOR AVAILABILITY</div>`;
}

function render() {
  renderNav();
  renderAdminBar();
  renderContent();
  if (isAdmin) document.body.classList.add('admin-mode');
  else document.body.classList.remove('admin-mode');
}

// Password modal
function openPassModal() {
  document.getElementById('pass-input').value = '';
  document.getElementById('pass-error').style.display = 'none';
  document.getElementById('pass-input').classList.remove('pass-input-error');
  document.getElementById('pass-modal').style.display = 'flex';
  setTimeout(() => document.getElementById('pass-input').focus(), 50);
}
function closePassModal() {
  document.getElementById('pass-modal').style.display = 'none';
}
function clearPassError() {
  document.getElementById('pass-error').style.display = 'none';
  document.getElementById('pass-input').classList.remove('pass-input-error');
}
function submitPass() {
  const val = document.getElementById('pass-input').value;
  if (val === PASS) {
    isAdmin = true;
    closePassModal();
    render();
  } else {
    document.getElementById('pass-error').style.display = 'block';
    document.getElementById('pass-input').classList.add('pass-input-error');
  }
}
function signOut() {
  isAdmin = false;
  render();
}

// Add modal
function openAddModal() {
  const sel = document.getElementById('af-sec');
  sel.innerHTML = sections.map(s => `<option value="${s.id}">${s.title}</option>`).join('');
  document.getElementById('af-name').value = '';
  document.getElementById('af-desc').value = '';
  document.getElementById('af-recon').value = '';
  document.getElementById('af-dose').value = '';
  document.getElementById('add-modal').style.display = 'flex';
  setTimeout(() => document.getElementById('af-name').focus(), 50);
}
function closeAddModal() {
  document.getElementById('add-modal').style.display = 'none';
}
function submitAdd() {
  const sid = document.getElementById('af-sec').value;
  const name = document.getElementById('af-name').value.trim();
  const desc = document.getElementById('af-desc').value.trim();
  const recon = document.getElementById('af-recon').value.trim();
  const dose = document.getElementById('af-dose').value.trim();
  if (!name) { alert('Please enter a peptide name.'); return; }
  const sec = sections.find(s => s.id === sid);
  if (sec) sec.peptides.push({ id: 'p-' + Date.now(), name, desc, recon, dose });
  closeAddModal();
  render();
}

// Delete
function deleteCard(sid, pid) {
  if (!confirm('Delete this peptide?')) return;
  const sec = sections.find(s => s.id === sid);
  if (sec) sec.peptides = sec.peptides.filter(p => p.id !== pid);
  render();
}

render();
</script>
</body>
</html>
