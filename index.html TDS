    .content { max-width: 1000px; margin: 0 auto; padding: 32px 16px 60px; }
    .section { margin-bottom: 48px; }
    .section-hdr { display: flex; align-items: center; margin-bottom: 20px; }
    .section-bar { width: 3px; height: 26px; background: #E02020; border-radius: 2px; margin-right: 12px; flex-shrink: 0; }
    .section-title { font-size: 14px; font-weight: 700; letter-spacing: 3px; }
    .section-line { height: 1px; background: linear-gradient(to right, #E02020, transparent); margin-top: 8px; }
    .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 12px; }
    .card { background: #1C1C1C; border: 1px solid #2A2A2A; border-radius: 8px; padding: 16px; position: relative; }
    .card-name { color: #E02020; font-weight: 700; font-size: 13px; margin-bottom: 4px; letter-spacing: .3px; }
    .card-desc { color: #BBBBBB; font-size: 11px; line-height: 1.55; margin-bottom: 10px; }
    .card-divider { border-top: 1px solid #3A0000; padding-top: 8px; margin-bottom: 7px; }
    .card-label { color: #C41A1A; font-size: 8px; font-weight: 700; letter-spacing: 1.5px; margin-bottom: 4px; }
    .card-recon { color: #F0F0F0; font-size: 11px; line-height: 1.55; }
    .card-dose-wrap { margin-top: 7px; }
    .card-dose { color: #BBBBBB; font-size: 11px; line-height: 1.55; }
    .delete-btn { position: absolute; top: 10px; right: 10px; background: none; border: 1px solid #3a0000; border-radius: 4px; color: #C41A1A; font-size: 9px; padding: 2px 7px; letter-spacing: 1px; display: none; }
    body.admin-mode .delete-btn { display: block; }
    body.admin-mode .card-name { padding-right: 80px; }
    .overlay { position: fixed; inset: 0; background: rgba(0,0,0,.9); display: flex; align-items: center; justify-content: center; z-index: 999; }
    .modal { background: #1C1C1C; border: 1px solid #2A2A2A; border-radius: 10px; padding: 32px; width: 300px; }
    .modal-add { width: 420px; max-width: 95vw; max-height: 90vh; overflow-y: auto; padding: 28px; }
    .modal-title { font-size: 13px; font-weight: 700; letter-spacing: 2px; color: #F0F0F0; margin-bottom: 5px; }
    .modal-sub { font-size: 10px; color: #555; margin-bottom: 20px; letter-spacing: 1px; }
    .field-label { font-size: 9px; color: #C41A1A; letter-spacing: 1.5px; font-weight: 700; margin-bottom: 5px; }
    .field-wrap { margin-bottom: 14px; }
    .field-wrap:last-of-type { margin-bottom: 22px; }
    .field-input { width: 100%; background: #242424; border: 1px solid #383838; border-radius: 4px; color: #F0F0F0; padding: 8px 10px; font-size: 12px; }
    .field-input:focus { outline: none; border-color: #555; }
    .field-textarea { width: 100%; background: #242424; border: 1px solid #383838; border-radius: 4px; color: #F0F0F0; padding: 8px 10px; font-size: 12px; resize: vertical; }
