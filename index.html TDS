<!-- Password Modal -->
<div class="overlay" id="pass-modal" style="display:none" onclick="if(event.target===this)closePassModal()">
  <div class="modal">
    <div class="modal-title">ADMIN ACCESS</div>
    <div class="modal-sub">Enter your admin password to continue.</div>
    <input class="pass-input" id="pass-input" type="password" placeholder="Password"
      oninput="clearPassError()" onkeydown="if(event.key==='Enter')submitPass()">
    <div class="pass-error" id="pass-error">INCORRECT PASSWORD</div>
    <div class="btn-row">
      <button class="btn-primary" onclick="submitPass()">ENTER</button>
      <button class="btn-secondary" onclick="closePassModal()">CANCEL</button>
    </div>
  </div>
</div>

<!-- Add Peptide Modal -->
<div class="overlay" id="add-modal" style="display:none" onclick="if(event.target===this)closeAddModal()">
