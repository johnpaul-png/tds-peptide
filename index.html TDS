    <div class="field-wrap" style="margin-bottom:22px">
      <div class="field-label">DOSING</div>
      <textarea class="field-textarea" id="af-dose" placeholder="Dosing instructions..." rows="2"></textarea>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn-primary" onclick="submitAdd()">ADD PEPTIDE</button>
      <button class="btn-secondary" onclick="closeAddModal()">CANCEL</button>
    </div>
  </div>
</div>

