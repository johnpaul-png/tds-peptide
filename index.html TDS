    .nav-bar::-webkit-scrollbar { display: none; }
    .nav-btn { background: none; border: none; border-right: 1px solid #1e1e1e; color: #666; font-size: 9px; letter-spacing: 1.2px; white-space: nowrap; padding: 5px 12px; flex-shrink: 0; transition: color .15s; }
